{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "Lua 5.1",
  "runtime.nonstandardSymbol": [
    "!=",
    "continue",
    "//"
  ],
  "workspace.ignoreDir": [
    "libs",
    ".libraries",
    ".git",
    ".vscode",
    ".claude"
  ],
  "diagnostics.workspaceDelay": 3000,
  "diagnostics.disable": [
    "lowercase-global",
    "duplicate-set-field",
    "missing-fields",
    "inject-field",
    "cast-local-type",
    "param-type-mismatch",
    "return-type-mismatch"
  ],
  "diagnostics.globals": [
    "AutoBodyResDB",
    "SLASH_ABR1",
    "SLASH_ABR2",
    "SlashCmdList",
    "LibStub",
    "CreateFrame",
    "UIParent",
    "C_Timer",
    "C_PvP",
    "C_DeathInfo",
    "UnitClass",
    "UnitIsDeadOrGhost",
    "IsInInstance",
    "GetTime",
    "GetClassColor",
    "GetInstanceInfo",
    "GetCorpseRecoveryDelay",
    "GetAreaSpiritHealerTime",
    "GetSelfResurrectOptions",
    "GetActiveBrawlInfo",
    "GetAvailableBrawlInfo",
    "AcceptResurrect",
    "StaticPopupDialogs",
    "StaticPopup_Show",
    "StaticPopup_Hide",
    "hooksecurefunc",
    "CopyTable",
    "format",
    "wipe"
  ],
  "completion.callSnippet": "Replace",
  "completion.keywordSnippet": "Replace",
  "hint.enable": true,
  "hint.setType": true,
  "semantic.enable": true,
  "telemetry.enable": false
}
